{
  "name": "directo",
  "version": "0.1.0",
  "description": "Navigate your organization's knowledge graph",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "knowledge-graph",
    "organization",
    "expert-finder",
    "semantic-search",
    "ai"
  ],
  "author": "İsmail Perim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ismailperim/directo.git"
  },
  "bugs": {
    "url": "https://github.com/ismailperim/directo/issues"
  },
  "homepage": "https://github.com/ismailperim/directo#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
